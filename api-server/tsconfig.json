{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "dist",
    "rootDir": "src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    // "baseUrl": ".",  <-- REMOVA ESTA LINHA
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": ["src/**/*"]
}